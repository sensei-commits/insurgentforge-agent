# ============================================================
# INSURGENTFORGE AGENT — CREDENTIALS TEMPLATE
# Copy this file to ".env" and fill in your real values.
# NEVER commit .env (it's gitignored). This .example file is safe to commit.
# ============================================================

# ── 1. DATABASE (Railway Postgres — same DB Helena uses) ────
# Railway → your Postgres service → "Connect" tab → copy the connection string.
# Looks like: postgresql://user:pass@host:port/dbname
DATABASE_URL=

# ── 2. AI PROVIDERS (reuse your existing Helena keys) ───────
# DeepSeek (paid, used for quality writing): https://platform.deepseek.com
DEEPSEEK_API_KEY=
# Groq (free, fast, bulk work): https://console.groq.com
GROQ_API_KEY=
# Gemini (free fallback): https://ai.google.dev
GEMINI_API_KEY=

# ── 3. REDDIT (free API — for posting + research) ───────────
# Create an app at: https://www.reddit.com/prefs/apps  (type: "script")
# Guide will walk you through this in Phase L.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# A unique identifier for your bot, e.g. "insurgentforge-agent/0.1 by u/iNFAMOUSII8"
REDDIT_USER_AGENT=insurgentforge-agent/0.1 by u/iNFAMOUSII8

# ── 4. DISCORD (new bot for the InsurgentForge server) ──────
# Create at: https://discord.com/developers/applications  → New Application → Bot → Reset Token
# Guide will walk you through this in Phase L.
DISCORD_TOKEN=
# Your InsurgentForge server ID (right-click server → Copy Server ID; needs Developer Mode on)
DISCORD_GUILD_ID=
# The #trends channel ID (right-click channel → Copy Channel ID)
DISCORD_TRENDS_CHANNEL_ID=
# Your own Discord user ID, so the bot can @ping you (right-click your name → Copy User ID)
DISCORD_OWNER_ID=

# ── 5. BLUESKY (free auto-post) ─────────────────────────────
# Handle e.g. insurgentforge.bsky.social ; App password from Settings → App Passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── 6. MASTODON (free auto-post) ────────────────────────────
# Instance URL e.g. https://fosstodon.org ; token from Preferences → Development → New Application
MASTODON_INSTANCE_URL=
MASTODON_ACCESS_TOKEN=

# ── 7. DEV.TO (free auto-post articles) ─────────────────────
# API key from dev.to → Settings → Extensions → DEV Community API Keys
DEVTO_API_KEY=

# ── 8. TUNING ───────────────────────────────────────────────
# Independent sources required to mark an opportunity "ironclad" (default 3). Higher = stricter.
IRONCLAD_MIN_SOURCES=3
